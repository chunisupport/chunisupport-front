{
  "name": "chunisupport-front",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "rsbuild build",
    "dev": "rsbuild dev --open",
    "start": "rsbuild dev --open",
    "preview": "rsbuild preview",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint --write .",
    "lint:check": "biome lint .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "typecheck": "tsc --noEmit --pretty false",
    "verify": "pnpm check:ci && pnpm typecheck && pnpm build && pnpm test:unit",
    "licenses:check": "node scripts/generate-licenses.mjs --check",
    "licenses:generate": "node scripts/generate-licenses.mjs",
    "test:unit": "node --import ./scripts/register-ts-extension-loader.mjs --disable-warning=ExperimentalWarning --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/router": "^0.16.1",
    "@tanstack/solid-virtual": "^3.13.30",
    "chart.js": "^4.5.1",
    "dexie": "^4.4.4",
    "firebase": "^12.15.0",
    "lucide-solid": "^1.21.0",
    "solid-js": "^1.9.13",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@rsbuild/core": "^2.1.1",
    "@rsbuild/plugin-babel": "^2.0.0",
    "@rsbuild/plugin-solid": "^1.2.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "fake-indexeddb": "^6.2.5",
    "generate-license-file": "^4.2.1",
    "typescript": "^6.0.3"
  }
}
