{
  "name": "chunisupport-front",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "dev": "rsbuild dev --open",
    "start": "rsbuild dev --open",
    "preview": "rsbuild preview",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint --write .",
    "lint:check": "biome lint .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "licenses:check": "node scripts/generate-licenses.mjs --check",
    "licenses:generate": "node scripts/generate-licenses.mjs",
    "test:unit": "node --import ./scripts/register-ts-extension-loader.mjs --disable-warning=ExperimentalWarning --test src/**/*.test.ts"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/router": "^0.15.4",
    "@tanstack/solid-virtual": "^3.13.22",
