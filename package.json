{
  "name": "chunisupport-front",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "dev": "rsbuild dev --open",
    "start": "rsbuild dev --open",
    "preview": "rsbuild preview",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint --write .",
    "lint:check": "biome lint .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "test:unit": "PUBLIC_FB_API_KEY=dummy PUBLIC_FB_AUTH_DOMAIN=dummy PUBLIC_FB_PROJECT_ID=dummy PUBLIC_FB_STORAGE_BUCKET=dummy PUBLIC_FB_MESSAGING_SENDER_ID=dummy PUBLIC_FB_APP_ID=dummy PUBLIC_BACKEND_URL=http://localhost node --loader ./scripts/resolve-ts-extension-loader.mjs --test src/api/fetchWithAuth.test.ts src/usecases/auth/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/router": "^0.15.4",
    "@tanstack/solid-virtual": "^3.13.22",
    "firebase": "^12.11.0",
    "lucide-solid": "^0.562.0",
    "solid-js": "^1.9.10",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@rsbuild/core": "^1.7.1",
    "@rsbuild/plugin-babel": "^1.0.6",
    "@rsbuild/plugin-solid": "^1.0.6",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.5.2",
    "typescript": "^5.9.3"
  }
}
